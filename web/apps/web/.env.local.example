# Firebase Web App config
# Obtener de: Firebase Console > Project Settings > Your apps > Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=geoagent-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=geoagent-app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=geoagent-app.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=609077404870
NEXT_PUBLIC_FIREBASE_APP_ID=

# Google Maps JavaScript API key
# Obtener de: Google Cloud Console > APIs & Services > Credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Firebase Cloud Messaging — VAPID key para Web Push
# Firebase Console > Project Settings > Cloud Messaging > Web Push certificates > Add certificate
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Google Search Console — token de verificación de propiedad
# Search Console > Add property > Verificación HTML tag (solo el contenido del meta tag)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# reCAPTCHA v3 — para Firebase App Check en web
# console.recaptcha.google.com > Crear sitio v3 para web-taupe-three-27.vercel.app
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
